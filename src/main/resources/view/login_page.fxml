<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane prefWidth="800" prefHeight="600"
           style="-fx-background-color: linear-gradient(to bottom right, #6366f1, #a855f7);"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.java_lms_group_20.Controller.LoginController">

    <VBox alignment="CENTER" maxWidth="400" maxHeight="500" spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 15);">

        <padding>
            <Insets top="50" right="40" bottom="50" left="40"/>
        </padding>


        <Region prefHeight="20"/>

        <Label text="Welcome Back"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
        <Label text="Enter your details to access your dashboard"
               style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>

        <Region prefHeight="35"/>

        <VBox spacing="20">
            <VBox spacing="8">
                <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 12px;"/>
                <TextField fx:id="usernameField" promptText="Your username"
                           style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 12px;"/>
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;"/>
            </VBox>
        </VBox>

        <Region prefHeight="10"/>

        <HBox alignment="CENTER_RIGHT">
            <Hyperlink text="Forgot Password?" style="-fx-text-fill: #6366f1; -fx-font-size: 12px; -fx-underline: false;"/>
        </HBox>

        <Region prefHeight="25"/>

        <Button fx:id="loginButton" text="Continue" onAction="#handleLogin" defaultButton="true"
                maxWidth="Infinity"
                style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 10; -fx-padding: 14; -fx-cursor: hand;"/>

        <Region prefHeight="15"/>

        <Label fx:id="messageLabel" text="" wrapText="true" textAlignment="CENTER"
               style="-fx-text-fill: #DC2626; -fx-font-size: 12px;"/>

    </VBox>
</StackPane>